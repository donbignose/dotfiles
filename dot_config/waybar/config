{
	"layer": "top",
	"position": "top",
	"height": 38,
	"margin-top": 4,
	"margin-left": 8,
	"margin-right": 8,
	"modules-left": [
		"hyprland/workspaces",
		"hyprland/window"
	],
	"modules-center": [
		"custom/media",
		"clock"
	],
	"modules-right": [
		"custom/updates",
		"group/system",
		"pulseaudio#output",
		"network",
		"bluetooth",
		"tray",
		"idle_inhibitor",
		"custom/notification",
		"custom/power"
	],
	"hyprland/workspaces": {
		"format": "{windows}",
		"format-window-separator": " ",
		"window-rewrite-default": "ï„¨",
		"window-rewrite": {
			"kitty": "ï’‰",
			"zen": "َ°ˆ¹",
			"org.mozilla.Thunderbird": "َ°‡®",
			"dev.zed.Zed": "َ°ک¤",
			"discord": "َ°™¯",
			"Spotify": "َ°“‡",
			"steam": "َ°““",
			"org.pulseaudio.pavucontrol": "َ°•¾",
			"scratchpad": "ï’‰",
			"btop-scratchpad": "َ°¨‡",
			"spotify": "َ°“‡"
		},
		"on-click": "activate",
		"sort-by-number": true,
		"persistent-workspaces": {
			"*": 5
		}
	},
	"hyprland/window": {
		"format": "{}",
		"max-length": 40,
		"separate-outputs": true
	},
	"clock": {
		"interval": 1,
		"format": "{:%H:%M}",
		"format-alt": "{:%A, %B %d}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
	},
	"custom/updates": {
		"format": "َ°†‡ {}",
		"exec": "checkupdates 2>/dev/null | wc -l",
		"interval": 3600,
		"tooltip": false,
		"on-click": "kitty -e sudo pacman -Syu"
	},
	"group/system": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 400,
			"children-class": "system-drawer",
			"transition-left-to-right": false
		},
		"modules": [
			"cpu",
			"memory",
			"temperature",
			"disk"
		]
	},
	"cpu": {
		"interval": 3,
		"format": "َ°چ› {usage}%"
	},
	"memory": {
		"interval": 5,
		"format": "ï‹› {}%",
		"on-click": "kitty -e btop",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},
	"temperature": {
		"interval": 3,
		"critical-threshold": 80,
		"format-critical": "َ°¸پ {temperatureC}آ°C",
		"format": "ï‹‰ {temperatureC}آ°C"
	},
	"disk": {
		"interval": 30,
		"format": "َ°‡… {percentage_used}%",
		"path": "/"
	},
	"pulseaudio#output": {
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "َ°—، muted",
		"format-icons": {
			"headphone": "َ°‹‹",
			"default": [
				"ï€¦",
				"ï€§",
				"ï€¨"
			]
		},
		"on-click": "swayosd-client --output-volume mute-toggle",
		"on-click-right": "pavucontrol",
		"on-scroll-up": "swayosd-client --output-volume raise",
		"on-scroll-down": "swayosd-client --output-volume lower"
	},
	"network": {
		"format-wifi": "ï‡«  {essid}",
		"format-ethernet": "َ°ˆ€ {ipaddr}",
		"format-disconnected": "َ°¤® ",
		"format-alt": "ïپ¢ {bandwidthUpBits} ïپ£ {bandwidthDownBits}",
		"tooltip-format": "َ°ˆ€ {ifname}\nïپ¢ {ipaddr}/{cidr}\nïپ¢ {bandwidthUpBytes} ïپ£ {bandwidthDownBytes}",
		"interval": 5
	},
	"bluetooth": {
		"format": "َ°‚¯",
		"format-connected": "َ°‚± {device_alias}",
		"format-connected-battery": "َ°‚± {device_alias} {device_battery_percentage}%",
		"format-disabled": "َ°‚²",
		"format-off": "َ°‚²",
		"tooltip-format": "{controller_alias}\n{num_connections} connected",
		"tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_battery_percentage}%",
		"on-click": "rofi-bluetooth",
		"on-click-right": "bluetoothctl power toggle"
	},
	"tray": {
		"spacing": 8,
		"icon-size": 16
	},
	"custom/power": {
		"format": "âڈ»",
		"tooltip": false,
		"on-click": "$HOME/.local/bin/power-menu"
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "َ°…¶",
			"deactivated": "َ°›ٹ"
		}
	},
	"custom/notification": {
		"tooltip": false,
		"format": "{icon}",
		"format-icons": {
			"notification": "َ°‚ڑ",
			"none": "َ°‚›",
			"dnd-notification": "َ°‚œ",
			"dnd-none": "َ°‚‌",
			"inhibited-notification": "َ°‚ڑ",
			"inhibited-none": "َ°‚›",
			"dnd-inhibited-notification": "َ°‚œ",
			"dnd-inhibited-none": "َ°‚‌"
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true
	},
	"custom/media": {
		"format": "{}",
		"max-length": 50,
		"exec": "$HOME/.local/bin/waybar-media",
		"on-click": "playerctl play-pause 2>/dev/null || spotify-launcher",
		"on-click-right": "playerctl next",
		"on-scroll-up": "playerctl next",
		"on-scroll-down": "playerctl previous",
		"escape": true,
		"restart-interval": 5
	}
}

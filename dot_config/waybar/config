{
	"layer": "top",
	"position": "top",
	"height": 38,
	"margin-top": 4,
	"margin-left": 8,
	"margin-right": 8,

	"modules-left": ["hyprland/workspaces", "hyprland/window"],
	"modules-center": ["clock"],
	"modules-right": ["custom/updates", "cpu", "memory", "temperature", "disk", "pulseaudio#output", "network", "tray", "custom/power"],

	"hyprland/workspaces": {
		"format": "{id}",
		"on-click": "activate",
		"sort-by-number": true,
		"persistent-workspaces": {
			"*": 5
		}
	},

	"hyprland/window": {
		"format": "{}",
		"max-length": 40,
		"separate-outputs": true
	},

	"clock": {
		"interval": 1,
		"format": "{:%H:%M}",
		"format-alt": "{:%A, %B %d}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
	},

	"custom/updates": {
		"format": "󰏗 {}",
		"exec": "checkupdates 2>/dev/null | wc -l",
		"interval": 3600,
		"tooltip": false,
		"on-click": "kitty -e sudo pacman -Syu"
	},

	"cpu": {
		"interval": 3,
		"format": "󰍛 {usage}%"
	},

	"memory": {
		"interval": 5,
		"format": " {}%",
		"on-click": "kitty -e btop",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},

	"temperature": {
		"interval": 3,
		"critical-threshold": 80,
		"format-critical": "󰸁 {temperatureC}°C",
		"format": " {temperatureC}°C"
	},

	"disk": {
		"interval": 30,
		"format": "󰇅 {percentage_used}%",
		"path": "/"
	},

	"pulseaudio#output": {
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "󰖁 muted",
		"format-icons": {
			"headphone": "󰋋",
			"default": ["", "", ""]
		},
		"on-click": "swayosd-client --output-volume mute-toggle",
		"on-click-right": "pavucontrol",
		"on-scroll-up": "swayosd-client --output-volume raise",
		"on-scroll-down": "swayosd-client --output-volume lower"
	},

	"network": {
		"format-wifi": "  {essid}",
		"format-ethernet": "󰈀 {ipaddr}",
		"format-disconnected": "󰤮 ",
		"format-alt": " {bandwidthUpBits}  {bandwidthDownBits}",
		"tooltip-format": "󰈀 {ifname}\n {ipaddr}/{cidr}\n {bandwidthUpBytes}  {bandwidthDownBytes}",
		"interval": 5
	},

	"tray": {
		"spacing": 8,
		"icon-size": 16
	},

	"custom/power": {
		"format": "⏻",
		"tooltip": false,
		"on-click": "wlogout"
	}
}

{
	"layer": "top",
	"position": "top",
	"height": 32,
	"modules-left": ["hyprland/workspaces", "hyprland/window", "custom/spotify"],
	"modules-center": ["clock", "custom/weather"],
	"modules-right": ["idle_inhibitor", "pulseaudio#output", "disk", "memory", "cpu", "temperature", "network", "custom/divider", "tray"],

	// Left Modules
	"hyprland/workspaces": {
		"format": "{icon}",
		"format-icons": {
			"1": "",
			"2": "󰈹",
			"3": "",
			"4": "",
			"5": "",
			"urgent": "",
			"active": "",
			"default": ""
		},
		"on-click": "activate",
		"sort-by-number": true,
		"persistent-workspaces": {
			"*": 5
		}
	},

	"hyprland/window": {
		"format": "| {}",
		"max-length": 50,
		"rewrite": {
			"(.*)Firefox(.*)": "| 󰈹 Firefox",
			"(.*)Discord(.*)": "| 󰙯 Discord",
			"(.*)Spotify(.*)": "|  Spotify",
			"(.*)Steam(.*)": "| 󰓓 Steam",
			"(.*)kitty(.*)": "|  Kitty",
			"(.*)nvim(.*)": "|  Neovim"
		}
	},

	"custom/spotify": {
		"exec": "/usr/bin/python3 ~/.config/waybar/scripts/mediaplayer.py --player spotifyd",
		"format": "|  {}",
		"return-type": "json",
		"on-click": "playerctl play-pause",
		"on-scroll-up": "playerctl next",
		"on-scroll-down": "playerctl previous"
	},

	// Center Modules
	"clock": {
		"interval": 1,
		"format": "{:%X | %A, %B %d, %Y}  |",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
	},

	"custom/weather": {
		"exec": "python ~/.config/waybar/scripts/weather.py",
		"restart-interval": 300,
		"return-type": "json",
		"on-click": "xdg-open https://weather.com"
	},

	// Right Modules
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "",
			"deactivated": ""
		}
	},

	"pulseaudio#output": {
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-bluetooth": "{volume}% {icon}  {format_source}",
		"format-bluetooth-muted": " {icon}  {format_source}",
		"format-muted": "",
		"format-icons": {
			"headphone": "󰋋 ",
			"hands-free": "וֹ",
			"headset": "  ",
			"phone": "",
			"portable": "",
			"car": "",
			"default": [""]
		},
		"on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"on-click-right": "pavucontrol",
		"on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
		"on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
	},

	"disk": {
		"interval": 30,
		"format": "󰇅  {percentage_used}%",
		"path": "/"
	},

	"memory": {
		"interval": 5,
		"format": " {}%",
		"on-click": "kitty -e btop",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},

	"cpu": {
		"interval": 1,
		"format": "󰍛 {usage}%",
		"max-length": 10
	},

	"temperature": {
		"interval": 1,
		"critical-threshold": 80,
		"format-critical": "󰸁 {temperatureC}°C",
		"format": " {temperatureC}°C"
	},

	"network": {
		"format": "󱘖 {ipaddr}",
		"format-wifi": "{essid}",
		"format-ethernet": "ETH-IP: {ipaddr}",
		"format-linked": "{ifname} (No IP)",
		"format-disconnected": "󰤮 Disconnected",
		"format-alt": "{ifname}: {ipaddr}/{cidr}",
		"tooltip-format": " {bandwidthUpBytes}  {bandwidthDownBytes}",
		"interval": 1
	},

	"custom/divider": {
		"format": "|"
	},

	"tray": {
		"spacing": 4
	}
}

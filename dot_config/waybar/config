{
	"layer": "top",
	"position": "top",
	"height": 38,
	"margin-top": 4,
	"margin-left": 8,
	"margin-right": 8,
	"modules-left": [
		"hyprland/workspaces",
		"hyprland/window"
	],
	"modules-center": [
		"group/media-pill",
		"clock"
	],
	"modules-right": [
		"custom/updates",
		"group/system",
		"pulseaudio#output",
		"network",
		"tray",
		"idle_inhibitor",
		"custom/notification",
		"custom/power"
	],
	"hyprland/workspaces": {
		"format": "{windows}",
		"format-window-separator": " ",
		"window-rewrite-default": "",
		"window-rewrite": {
			"kitty": "",
			"zen": "󰈹",
			"org.mozilla.Thunderbird": "󰇮",
			"dev.zed.Zed": "󰘤",
			"discord": "󰙯",
			"Spotify": "󰓇",
			"steam": "󰓓",
			"org.pulseaudio.pavucontrol": "󰕾",
			"scratchpad": "",
			"btop-scratchpad": "󰨇",
			"spotify": "󰓇"
		},
		"on-click": "activate",
		"sort-by-number": true,
		"persistent-workspaces": {
			"*": 5
		}
	},
	"hyprland/window": {
		"format": "{}",
		"max-length": 40,
		"separate-outputs": true
	},
	"clock": {
		"interval": 1,
		"format": "{:%H:%M}",
		"format-alt": "{:%A, %B %d}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
	},
	"custom/updates": {
		"format": "󰆇 {}",
		"exec": "checkupdates 2>/dev/null | wc -l",
		"interval": 3600,
		"tooltip": false,
		"on-click": "kitty -e sudo pacman -Syu"
	},
	"group/system": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 400,
			"children-class": "system-drawer",
			"transition-left-to-right": false
		},
		"modules": [
			"cpu",
			"memory",
			"temperature",
			"disk"
		]
	},
	"cpu": {
		"interval": 3,
		"format": "󰍛 {usage}%"
	},
	"memory": {
		"interval": 5,
		"format": " {}%",
		"on-click": "kitty -e btop",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},
	"temperature": {
		"interval": 3,
		"critical-threshold": 80,
		"format-critical": "󰸁 {temperatureC}°C",
		"format": " {temperatureC}°C"
	},
	"disk": {
		"interval": 30,
		"format": "󰇅 {percentage_used}%",
		"path": "/"
	},
	"pulseaudio#output": {
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "󰗡 muted",
		"format-icons": {
			"headphone": "󰋋",
			"default": [
				"",
				"",
				""
			]
		},
		"on-click": "swayosd-client --output-volume mute-toggle",
		"on-click-right": "pavucontrol",
		"on-scroll-up": "swayosd-client --output-volume raise",
		"on-scroll-down": "swayosd-client --output-volume lower"
	},
	"network": {
		"format-wifi": "  {essid}",
		"format-ethernet": "󰈀 {ipaddr}",
		"format-disconnected": "󰤮 ",
		"format-alt": " {bandwidthUpBits}  {bandwidthDownBits}",
		"tooltip-format": "󰈀 {ifname}\n {ipaddr}/{cidr}\n {bandwidthUpBytes}  {bandwidthDownBytes}",
		"interval": 5
	},
	"tray": {
		"spacing": 8,
		"icon-size": 16
	},
	"custom/power": {
		"format": "⏻",
		"tooltip": false,
		"on-click": "$HOME/.local/bin/power-menu"
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "󰅶",
			"deactivated": "󰛊"
		}
	},
	"custom/notification": {
		"tooltip": false,
		"format": "{icon}",
		"format-icons": {
			"notification": "󰂚",
			"none": "󰂛",
			"dnd-notification": "󰂜",
			"dnd-none": "󰂝",
			"inhibited-notification": "󰂚",
			"inhibited-none": "󰂛",
			"dnd-inhibited-notification": "󰂜",
			"dnd-inhibited-none": "󰂝"
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true
	},
	"group/media-pill": {
		"orientation": "inherit",
		"modules": [
			"custom/media-icon",
			"custom/media-title",
			"custom/media-next"
		]
	},
	"custom/media-icon": {
		"format": "{icon}",
		"return-type": "json",
		"format-icons": {
			"Playing": "󰐊",
			"Paused": "󰐌",
			"default": "󰓇"
		},
		"exec": "playerctl -a metadata --format '{\"alt\": \"{{status}}\", \"tooltip\": \"{{playerName}}\"}' -F 2>/dev/null || echo '{\"alt\": \"default\", \"tooltip\": \"Open Spotify\"}'",
		"on-click": "playerctl -p spotify status 2>/dev/null && playerctl -p spotify play-pause || spotify-launcher",
		"interval": "once",
		"escape": true
	},
	"custom/media-title": {
		"format": "{}",
		"max-length": 30,
		"exec": "playerctl -a metadata --format '{{artist}} - {{title}}' -F 2>/dev/null",
		"on-click": "playerctl play-pause",
		"escape": true,
		"interval": "once"
	},
	"custom/media-next": {
		"format": "󰒭",
		"tooltip": false,
		"on-click": "playerctl next"
	}
}

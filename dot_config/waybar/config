{
	"layer": "top",
	"position": "top",
	"height": 38,
	"margin-top": 4,
	"margin-left": 8,
	"margin-right": 8,
	"modules-left": [
		"hyprland/workspaces",
		"hyprland/window",
		"custom/media"
	],
	"modules-center": [
		"clock"
	],
	"modules-right": [
		"custom/updates",
		"group/system",
		"idle_inhibitor",
		"pulseaudio#output",
		"network",
		"tray",
		"custom/power"
	],
	"hyprland/workspaces": {
		"format": "{windows}",
		"format-window-separator": " ",
		"window-rewrite-default": "ï„¨",
		"window-rewrite": {
			"kitty": "ï’‰",
			"zen": "َ°ˆ¹",
			"org.mozilla.Thunderbird": "َ°‡®",
			"dev.zed.Zed": "َ°ک¤",
			"discord": "َ°™¯",
			"Spotify": "َ°“‡",
			"steam": "َ°““",
			"org.pulseaudio.pavucontrol": "َ°•¾",
			"scratchpad": "ï’‰",
			"btop-scratchpad": "َ°¨‡",
			"spotify": "َ°“‡"
		},
		"on-click": "activate",
		"sort-by-number": true,
		"persistent-workspaces": {
			"*": 5
		}
	},
	"hyprland/window": {
		"format": "{}",
		"max-length": 40,
		"separate-outputs": true
	},
	"clock": {
		"interval": 1,
		"format": "{:%H:%M}",
		"format-alt": "{:%A, %B %d}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
	},
	"custom/updates": {
		"format": "َ°†‡ {}",
		"exec": "checkupdates 2>/dev/null | wc -l",
		"interval": 3600,
		"tooltip": false,
		"on-click": "kitty -e sudo pacman -Syu"
	},
	"group/system": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 400,
			"children-class": "system-drawer",
			"transition-left-to-right": false
		},
		"modules": [
			"cpu",
			"memory",
			"temperature",
			"disk"
		]
	},
	"cpu": {
		"interval": 3,
		"format": "َ°چ› {usage}%"
	},
	"memory": {
		"interval": 5,
		"format": "ï‹› {}%",
		"on-click": "kitty -e btop",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},
	"temperature": {
		"interval": 3,
		"critical-threshold": 80,
		"format-critical": "َ°¸پ {temperatureC}آ°C",
		"format": "ï‹‰ {temperatureC}آ°C"
	},
	"disk": {
		"interval": 30,
		"format": "َ°‡… {percentage_used}%",
		"path": "/"
	},
	"pulseaudio#output": {
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "َ°—، muted",
		"format-icons": {
			"headphone": "َ°‹‹",
			"default": [
				"ï€¦",
				"ï€§",
				"ï€¨"
			]
		},
		"on-click": "swayosd-client --output-volume mute-toggle",
		"on-click-right": "pavucontrol",
		"on-scroll-up": "swayosd-client --output-volume raise",
		"on-scroll-down": "swayosd-client --output-volume lower"
	},
	"network": {
		"format-wifi": "ï‡«  {essid}",
		"format-ethernet": "َ°ˆ€ {ipaddr}",
		"format-disconnected": "َ°¤® ",
		"format-alt": "ïپ¢ {bandwidthUpBits} ïپ£ {bandwidthDownBits}",
		"tooltip-format": "َ°ˆ€ {ifname}\nïپ¢ {ipaddr}/{cidr}\nïپ¢ {bandwidthUpBytes} ïپ£ {bandwidthDownBytes}",
		"interval": 5
	},
	"tray": {
		"spacing": 8,
		"icon-size": 16
	},
	"custom/power": {
		"format": "âڈ»",
		"tooltip": false,
		"on-click": "wlogout"
	},
	"custom/media": {
		"format": "َ°“‡ {}",
		"max-length": 35,
		"exec": "playerctl metadata --format \"{{ artist }} - {{ title }}\" --follow 2>/dev/null",
		"on-click": "playerctl play-pause",
		"on-scroll-up": "playerctl next",
		"on-scroll-down": "playerctl previous"
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "ï‍¶",
			"deactivated": "ï‍²"
		}
	}
}

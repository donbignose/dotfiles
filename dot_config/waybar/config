{
	"layer": "top",
	"position": "top",
	"height": 38,
	"margin-top": 4,
	"margin-left": 8,
	"margin-right": 8,
	"modules-left": [
		"hyprland/workspaces",
		"hyprland/window"
	],
	"modules-center": [
		"clock"
	],
	"modules-right": [
		"custom/updates",
		"group/system",
		"pulseaudio#output",
		"network",
		"tray",
		"custom/power"
	],
	"hyprland/workspaces": {
		"format": "{id}: {windows}",
		"format-window-separator": " ",
		"window-rewrite-default": "ÔĄ®",
		"window-rewrite": {
			"kitty": "ÔíČ",
			"zen": "ůįąĻ",
			"org.mozilla.Thunderbird": "ůįáģ",
			"dev.zed.Zed": "ůįė§",
			"discord": "ůįôĮ",
			"Spotify": "ůįďá",
			"steam": "ůįďď",
			"org.pulseaudio.pavucontrol": "ůįēĺ",
			"scratchpad": "ÔíČ",
			"btop-scratchpad": "ůį®á"
		},
		"on-click": "activate",
		"sort-by-number": true,
		"persistent-workspaces": {
			"*": 5
		}
	},
	"hyprland/window": {
		"format": "{}",
		"max-length": 40,
		"separate-outputs": true
	},
	"clock": {
		"interval": 1,
		"format": "{:%H:%M}",
		"format-alt": "{:%A, %B %d}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
	},
	"custom/updates": {
		"format": "ůįÜá {}",
		"exec": "checkupdates 2>/dev/null | wc -l",
		"interval": 3600,
		"tooltip": false,
		"on-click": "kitty -e sudo pacman -Syu"
	},
	"group/system": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 400,
			"children-class": "system-drawer",
			"transition-left-to-right": false
		},
		"modules": [
			"cpu",
			"memory",
			"temperature",
			"disk"
		]
	},
	"cpu": {
		"interval": 3,
		"format": "ůįćõ {usage}%"
	},
	"memory": {
		"interval": 5,
		"format": "Ôčõ {}%",
		"on-click": "kitty -e btop",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},
	"temperature": {
		"interval": 3,
		"critical-threshold": 80,
		"format-critical": "ůįłĀ {temperatureC}¬įC",
		"format": "ÔčČ {temperatureC}¬įC"
	},
	"disk": {
		"interval": 30,
		"format": "ůįáÖ {percentage_used}%",
		"path": "/"
	},
	"pulseaudio#output": {
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "ůįó° muted",
		"format-icons": {
			"headphone": "ůįčč",
			"default": [
				"ÔÄ¶",
				"ÔÄß",
				"ÔÄ®"
			]
		},
		"on-click": "swayosd-client --output-volume mute-toggle",
		"on-click-right": "pavucontrol",
		"on-scroll-up": "swayosd-client --output-volume raise",
		"on-scroll-down": "swayosd-client --output-volume lower"
	},
	"network": {
		"format-wifi": "Ôáę  {essid}",
		"format-ethernet": "ůįąÄ {ipaddr}",
		"format-disconnected": "ůį§ģ ",
		"format-alt": "ÔĀĘ {bandwidthUpBits} ÔĀ£ {bandwidthDownBits}",
		"tooltip-format": "ůįąÄ {ifname}\nÔĀĘ {ipaddr}/{cidr}\nÔĀĘ {bandwidthUpBytes} ÔĀ£ {bandwidthDownBytes}",
		"interval": 5
	},
	"tray": {
		"spacing": 8,
		"icon-size": 16
	},
	"custom/power": {
		"format": "‚ŹĽ",
		"tooltip": false,
		"on-click": "wlogout"
	}
}

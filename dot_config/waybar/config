{
	"layer": "top",
	"position": "top",
	"height": 38,
	"margin-top": 4,
	"margin-left": 8,
	"margin-right": 8,

	"modules-left": ["hyprland/workspaces", "hyprland/window"],
	"modules-center": ["clock"],
	"modules-right": ["custom/updates", "group/system", "pulseaudio#output", "network", "tray", "custom/power"],

	// в”Ђв”Ђ Left в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

	"hyprland/workspaces": {
		"format": "{windows}",
		"format-icons": {
			"empty": "",
			"default": ""
		},
		"format-window-separator": " ",
		"window-rewrite-default": "",
		"window-rewrite": {
			"class<kitty>": "",
			"class<zen>": "у°€№",
			"class<org.mozilla.Thunderbird>": "у°‡®",
			"class<dev.zed.Zed>": "",
			"class<discord>": "у°™Ї",
			"class<Spotify>": "",
			"class<steam>": "у°““",
			"class<org.gnome.Calculator>": "",
			"class<org.pulseaudio.pavucontrol>": "",
			"class<btop-scratchpad>": "",
			"class<thunar>": "у°‰‹",
			"class<scratchpad>": ""
		},
		"on-click": "activate",
		"sort-by-number": true,
		"persistent-workspaces": {
			"*": 5
		}
	},

	"hyprland/window": {
		"format": "{icon} {title}",
		"icon": true,
		"icon-size": 16,
		"max-length": 40,
		"separate-outputs": true,
		"rewrite": {
			"(.*) вЂ” Zen Browser": "Zen",
			"(.*) вЂ” Mozilla Firefox": "Firefox",
			"(.*) - Mozilla Thunderbird": "Mail",
			"(.*) - Discord": "Discord",
			"(.*) вЂ” Spotify(.*)": "Spotify",
			"(.*) - Steam": "Steam"
		}
	},

	// в”Ђв”Ђ Center в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

	"clock": {
		"interval": 1,
		"format": "{:%H:%M}",
		"format-alt": "{:%A, %B %d}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
	},

	// в”Ђв”Ђ Right в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

	"custom/updates": {
		"format": "у°Џ— {}",
		"exec": "checkupdates 2>/dev/null | wc -l",
		"interval": 3600,
		"tooltip": false,
		"on-click": "kitty -e sudo pacman -Syu"
	},

	"group/system": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 400,
			"children-class": "system-drawer",
			"transition-left-to-right": false
		},
		"modules": ["cpu", "memory", "temperature", "disk"]
	},

	"cpu": {
		"interval": 3,
		"format": "у°Ќ› {usage}%"
	},

	"memory": {
		"interval": 5,
		"format": " {}%",
		"on-click": "kitty -e btop",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},

	"temperature": {
		"interval": 3,
		"critical-threshold": 80,
		"format-critical": "у°ёЃ {temperatureC}В°C",
		"format": " {temperatureC}В°C"
	},

	"disk": {
		"interval": 30,
		"format": "у°‡… {percentage_used}%",
		"path": "/"
	},

	"pulseaudio#output": {
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "у°–Ѓ muted",
		"format-icons": {
			"headphone": "у°‹‹",
			"default": ["", "", ""]
		},
		"on-click": "swayosd-client --output-volume mute-toggle",
		"on-click-right": "pavucontrol",
		"on-scroll-up": "swayosd-client --output-volume raise",
		"on-scroll-down": "swayosd-client --output-volume lower"
	},

	"network": {
		"format-wifi": "  {essid}",
		"format-ethernet": "у°€Ђ {ipaddr}",
		"format-disconnected": "у°¤® ",
		"format-alt": " {bandwidthUpBits}  {bandwidthDownBits}",
		"tooltip-format": "у°€Ђ {ifname}\n {ipaddr}/{cidr}\n {bandwidthUpBytes}  {bandwidthDownBytes}",
		"interval": 5
	},

	"tray": {
		"spacing": 8,
		"icon-size": 16
	},

	"custom/power": {
		"format": "вЏ»",
		"tooltip": false,
		"on-click": "wlogout"
	}
}

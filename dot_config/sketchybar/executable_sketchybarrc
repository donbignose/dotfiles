#!/bin/bash

source "$CONFIG_DIR/colors.sh"
PLUGIN_DIR="$CONFIG_DIR/plugins"
source "$CONFIG_DIR/items.sh"

# ── Bar Appearance ───────────────────────────────────────────
bar=(
	position=top
	sticky=on
	y_offset=4
	height=37
	margin=0
	padding_left=8
	padding_right=8
	corner_radius=0
	blur_radius=0
	color=$TRANSPARENT
	shadow=off
)
sketchybar --bar "${bar[@]}"

# ── Defaults ─────────────────────────────────────────────────
default=(
	icon.font="SF Pro:Semibold:17.0"
	label.font="SF Pro:Medium:13.0"
	icon.color=$FG_DIM
	label.color=$FG_COLOR
	padding_left=4
	padding_right=4
	background.color=$TRANSPARENT
	background.corner_radius=10
	background.height=28
	background.drawing=off
	icon.padding_left=8
	icon.padding_right=4
	label.padding_left=4
	label.padding_right=8
)
sketchybar --default "${default[@]}"

# ── Left ─────────────────────────────────────────────────────
spaces left
front_app left

# ── Right (ordered right-to-left) ────────────────────────────
power right
datetime right
spacer right 1
wifi right
bluetooth right
spacer right 2
volume right
spacer right 3
battery right
caffeine right
spacer right 4
docker right
spacer right 5
media right

# ── Apply pill backgrounds ───────────────────────────────────
apply_pills

sketchybar --update

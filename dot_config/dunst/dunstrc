# Dunst — Notification Daemon
# Kanagawa Wave Theme

[global]
    monitor = 0
    follow = mouse
    width = 350
    height = 300
    origin = top-right
    offset = 10x10
    notification_limit = 5
    progress_bar = true

    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 12
    frame_width = 2
    gap_size = 4
    separator_color = frame
    sort = yes

    font = JetBrains Mono Nerd Font 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    corner_radius = 8
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1F1F28"
    foreground = "#DCD7BA"
    frame_color = "#76946A"
    timeout = 5

[urgency_normal]
    background = "#1F1F28"
    foreground = "#DCD7BA"
    frame_color = "#98BB6C"
    timeout = 10

[urgency_critical]
    background = "#1F1F28"
    foreground = "#DCD7BA"
    frame_color = "#C34043"
    timeout = 0

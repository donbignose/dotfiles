{{ if eq .chezmoi.os "darwin" -}}
# Starship Prompt ‚Äî Vesper

palette = 'vesper'

format = """
[ÓÇ¥](fg:accent)$os[ÓÇ¥](fg:accent bg:surface)$directory[ÓÇ¥](fg:surface bg:border)$git_branch$git_status[ÓÇ¥](fg:border)$character"""

right_format = """[ÓÇ∂](fg:border)$nodejs$python$rust$golang$docker_context[ÓÇ∂](fg:surface bg:border)$cmd_duration[ÓÇ∂](fg:accent bg:surface)$time[ÓÇ¥](fg:accent)"""

[profiles]
transient = "$character"

[palettes.vesper]
bg = '#101010'
surface = '#232323'
border = '#343434'
fg = '#FFFFFF'
muted = '#505050'
dim = '#A0A0A0'
accent = '#FFC799'
mint = '#99FFE4'
red = '#FF8080'
deep = '#FF7300'

[os]
disabled = false
style = "fg:bg bg:accent bold"

[os.symbols]
Macos = " "

[directory]
style = "fg:fg bg:surface"
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "‚Ä¶/"

[git_branch]
symbol = "ÓÇÝ"
style = "fg:accent bg:border"
format = "[ $symbol $branch ]($style)"

[git_status]
style = "fg:dim bg:border"
format = "[$all_status$ahead_behind]($style)"
ahead = "[‚á°${count}](fg:mint bg:border) "
behind = "[‚á£${count}](fg:red bg:border) "
diverged = "[‚áÖ ‚á°${ahead_count} ‚á£${behind_count}](fg:red bg:border) "
modified = "[!${count}](fg:accent bg:border) "
staged = "[+${count}](fg:mint bg:border) "
untracked = "[?${count}](fg:dim bg:border) "
stashed = "[*${count}](fg:accent bg:border) "
deleted = "[‚úò${count}](fg:red bg:border) "

[nodejs]
style = "fg:mint bg:border"
format = "[ Óúò $version ]($style)"
detect_files = ["package.json", ".node-version"]

[python]
style = "fg:accent bg:border"
format = "[ Óúº $version ]($style)"

[rust]
style = "fg:red bg:border"
format = "[ Óû® $version ]($style)"

[golang]
style = "fg:mint bg:border"
format = "[ Óú§ $version ]($style)"

[docker_context]
style = "fg:mint bg:border"
format = "[ Û∞°® $context ]($style)"
only_with_files = true

[cmd_duration]
style = "fg:muted bg:surface"
format = "[ Û∞Öê $duration ]($style)"
min_time = 2_000

[time]
disabled = false
style = "fg:bg bg:accent bold"
format = "[ $time ]($style)"
time_format = "%H:%M"

[character]
success_symbol = "[‚ùØ](bold fg:accent)"
error_symbol = "[‚ùØ](bold fg:red)"
vimcmd_symbol = "[‚ùÆ](bold fg:mint)"
vimcmd_replace_symbol = "[‚ùÆ](bold fg:red)"
vimcmd_visual_symbol = "[‚ùÆ](bold fg:accent)"
{{- else -}}

# change window tiling mode
cmd + shift - space : yabai -m space --layout "$(yabai -m query --spaces --space | jq -r 'if .type == "bsp" then "stack" else "bsp" end')"

# change window focus within space
cmd - j : yabai -m window --focus south
cmd - k : yabai -m window --focus north
cmd - h : yabai -m window --focus west
cmd - l : yabai -m window --focus east

# Layout
# rotate layout clockwise
cmd + shift - r : yabai -m space --rotate 270
# flip along y-axis
cmd + shift - y : yabai -m space --mirror y-axis
# flip along x-axis
cmd + shift - x : yabai -m space --mirror x-axis
# toggle window float
cmd + shift - t : yabai -m window --toggle float --grid 4:4:1:1:2:2

# maximize a window
cmd + shift - m : yabai -m window --toggle zoom-fullscreen

# balance out tree of windows (resize to occupy same area)
cmd + shift - e : yabai -m space --balance

# Move Windows
# swap windows
cmd + shift - j : yabai -m window --swap south
cmd + shift - k : yabai -m window --swap north
cmd + shift - h : yabai -m window --swap west
cmd + shift - l : yabai -m window --swap east

# move window and split
cmd + ctrl - j : yabai -m window --warp south
cmd + ctrl - k : yabai -m window --warp north
cmd + ctrl - h : yabai -m window --warp west
cmd + ctrl - l : yabai -m window --warp east

# move window to display left and right
cmd + shift - s : yabai -m window --display west; yabai -m display --focus west;
cmd + shift - g : yabai -m window --display east; yabai -m display --focus east;

# move window to prev and next space (follow focus)
cmd + shift - p : yabai -m window --space prev; yabai -m space --focus prev; yabai -m window --focus recent
cmd + shift - n : yabai -m window --space next; yabai -m space --focus next; yabai -m window --focus recent

# move window to space # (follow focus)
cmd + shift - 1 : yabai -m window --space 1; yabai -m space --focus 1; yabai -m window --focus recent
cmd + shift - 2 : yabai -m window --space 2; yabai -m space --focus 2; yabai -m window --focus recent
cmd + shift - 3 : yabai -m window --space 3; yabai -m space --focus 3; yabai -m window --focus recent
cmd + shift - 4 : yabai -m window --space 4; yabai -m space --focus 4; yabai -m window --focus recent
cmd + shift - 5 : yabai -m window --space 5; yabai -m space --focus 5; yabai -m window --focus recent

# focus space directly
cmd - 1 : yabai -m space --focus 1
cmd - 2 : yabai -m space --focus 2
cmd - 3 : yabai -m space --focus 3
cmd - 4 : yabai -m space --focus 4
cmd - 5 : yabai -m space --focus 5

# Terminal
# open new Ghostty window (Super+Return on Linux)
cmd - return : open -na Ghostty

# Yabai
# stop/start/restart yabai
cmd + ctrl - q : yabai --stop-service
cmd + ctrl - s : yabai --start-service
cmd + ctrl - r : yabai --restart-service

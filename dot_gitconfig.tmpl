[user]
	name = {{ .chezmoi.username }}
	email = {{ .chezmoi.username }}@users.noreply.github.com

[init]
	defaultBranch = main

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true
	syntax-theme = Kanagawa
	line-numbers = true
	side-by-side = false

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[pull]
	rebase = true

[push]
	autoSetupRemote = true

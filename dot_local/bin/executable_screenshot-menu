#!/bin/bash
# Screenshot & Screen Recording Menu via Rofi

SCREENSHOT_DIR="$HOME/Pictures/Screenshots"
RECORDING_DIR="$HOME/Videos/Recordings"
mkdir -p "$SCREENSHOT_DIR" "$RECORDING_DIR"

TIMESTAMP=$(date +"%Y%m%d_%H%M%S")

# Check if already recording
if pgrep -x wf-recorder > /dev/null; then
    killall -SIGINT wf-recorder
    notify-send "Recording saved" "$RECORDING_DIR" -i camera-video
    exit 0
fi

CHOICE=$(printf "󰱝  Area → Save
󰍹  Screen → Save
󰆏  Area → Clipboard
󰴟  Screen → Clipboard
󰖮  Window → Save
󰓡  Record Area
󰓡  Record Screen" | rofi -dmenu -p "󰄀" -theme-str 'window { width: 320px; } listview { lines: 7; }')

case "$CHOICE" in
    *"Area → Save")
        grimblast --freeze save area "$SCREENSHOT_DIR/screenshot_$TIMESTAMP.png"
        ;;
    *"Screen → Save")
        grimblast save output "$SCREENSHOT_DIR/screenshot_$TIMESTAMP.png"
        ;;
    *"Area → Clipboard")
        grimblast --freeze copy area
        ;;
    *"Screen → Clipboard")
        grimblast copy output
        ;;
    *"Window → Save")
        grimblast --freeze save active "$SCREENSHOT_DIR/screenshot_$TIMESTAMP.png"
        ;;
    *"Record Area")
        GEOM=$(slurp)
        [ -n "$GEOM" ] && wf-recorder -g "$GEOM" -f "$RECORDING_DIR/recording_$TIMESTAMP.mp4" &
        notify-send "Recording started" "Press Super+Shift+P to stop" -i camera-video
        ;;
    *"Record Screen")
        wf-recorder -f "$RECORDING_DIR/recording_$TIMESTAMP.mp4" &
        notify-send "Recording started" "Press Super+Shift+P to stop" -i camera-video
        ;;
esac

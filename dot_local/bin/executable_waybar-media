#!/bin/bash
# Waybar media module — shows track with player-specific icon

while true; do
    if playerctl status &>/dev/null; then
        playerctl metadata --format '{{ playerName }}|||{{ artist }} - {{ title }}' --follow 2>/dev/null | while IFS='|||' read -r player rest; do
            case "$player" in
                spotify|Spotify) icon="󰓇" ;;
                firefox|zen|chromium) icon="󰈹" ;;
                *) icon="󰝚" ;;
            esac
            echo "$icon $rest"
        done
    else
        echo "󰓇  Spotify"
        sleep 5
    fi
done

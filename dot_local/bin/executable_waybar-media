#!/bin/bash
# Waybar media module ΓÇö shows controls when playing, spotify logo when idle

while true; do
    if playerctl status &>/dev/null; then
        playerctl metadata --format '≤░Æ«  ≤░ôç {{ artist }} - {{ title }}  ≤░Æ¡' --follow 2>/dev/null
    else
        echo "≤░ôç  Spotify"
        sleep 5
    fi
done

#!/bin/bash
# Waybar media module — shows track with player-specific icon

while true; do
    if playerctl status &>/dev/null; then
        PLAYER=$(playerctl metadata --format '{{ playerName }}' 2>/dev/null)
        case "$PLAYER" in
            firefox|zen|chromium) ICON="󰈹" ;;
            *) ICON="󰓇" ;;
        esac
        playerctl metadata --format "$ICON {{ artist }} - {{ title }}" --follow 2>/dev/null
    else
        echo "󰓇  Spotify"
        sleep 5
    fi
done

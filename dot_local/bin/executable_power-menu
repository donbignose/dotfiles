#!/bin/bash
# Power Menu via Rofi

CHOICE=$(printf "  Lock\n  Logout\n⏾  Suspend\n  Reboot\n  Shutdown" | rofi -dmenu -p "⏻" -theme-str 'window { width: 250px; } listview { lines: 5; }')

case "$CHOICE" in
    *Lock)      hyprlock ;;
    *Logout)    hyprctl dispatch exit ;;
    *Suspend)   systemctl suspend ;;
    *Reboot)    systemctl reboot ;;
    *Shutdown)  systemctl poweroff ;;
esac
